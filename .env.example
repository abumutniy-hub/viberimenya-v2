# =====================================
# ВЫБЕРИ МЕНЯ v2 — ENV EXAMPLE
# =====================================

NODE_ENV=development

# Project
APP_NAME="ВЫБЕРИ МЕНЯ"
APP_URL=http://localhost:3000
API_URL=http://localhost:4001
DEFAULT_SHOP_SLUG=viberimenya

# Database
DATABASE_URL=postgresql://viberimenya_app:CHANGE_ME@127.0.0.1:5432/viberimenya_v2

# Auth
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET

# Telegram
TELEGRAM_BOT_TOKEN=PASTE_BOT_TOKEN_HERE
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_TELEGRAM_WEBHOOK_SECRET

# Payments
PAYMENT_PROVIDER=manual
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
PAYMENT_TEST_MODE=true

# Uploads
UPLOADS_DIR=/var/www/viberimenya-v2/storage/uploads
PRIVATE_STORAGE_DIR=/var/www/viberimenya-v2/storage/private
