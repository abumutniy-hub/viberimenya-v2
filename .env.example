# =====================================
# ВЫБЕРИ МЕНЯ v2 — ENV EXAMPLE
# =====================================

NODE_ENV=development

# Project
APP_NAME="ВЫБЕРИ МЕНЯ"
APP_URL=http://localhost:3000
API_URL=http://localhost:4001
DEFAULT_SHOP_SLUG=viberimenya

# Database
DATABASE_URL=postgresql://viberimenya_app:CHANGE_ME@127.0.0.1:5432/viberimenya_v2

# Auth
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
COOKIE_SECRET=CHANGE_ME_COOKIE_SECRET

# Telegram
TELEGRAM_BOT_TOKEN=PASTE_BOT_TOKEN_HERE
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_TELEGRAM_WEBHOOK_SECRET

# Commerce core link (required when Telegram runs on another server)
COMMERCE_CORE_URL=http://127.0.0.1:4001
COMMERCE_TELEGRAM_SERVICE_TOKEN=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Payments
PAYMENT_PROVIDER=manual
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_TEST_MODE=true
YOOKASSA_RECEIPTS_ENABLED=false
YOOKASSA_VAT_CODE=1
YOOKASSA_TAX_SYSTEM_CODE=0
YOOKASSA_PAYMENT_MODE=full_payment
YOOKASSA_PAYMENT_SUBJECT=commodity
PAYMENT_PENDING_TTL_MINUTES=180
PAYMENT_EXPIRY_SWEEP_INTERVAL_MS=60000

# Uploads
UPLOADS_DIR=/var/www/viberimenya-v2/storage/uploads
PRIVATE_STORAGE_DIR=/var/www/viberimenya-v2/storage/private

# Address autocomplete (DaData; token remains on API server)
DADATA_API_TOKEN=
# Optional regional priority, e.g. KLADR prefix for the main delivery region
DADATA_LOCATION_BOOST_KLADR_ID=
DADATA_REQUEST_TIMEOUT_MS=4000
